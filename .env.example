# Copy this file to ".env" (same folder) and fill in the values below.
# See the README for the full explanation of each one.

# Private bot (Bot API, from @BotFather): /newbot on Telegram, paste the token here.
BOT_TOKEN=

# Telethon (user account, used by the scrapers in CLI/ and by the bot's Scrape):
# my.telegram.org -> "API development tools" -> create an app (any name) to get these.
TG_API_ID=
TG_API_HASH=
# Telethon session file name: leave as-is unless you manage multiple scraping accounts.
TG_SESSION_NAME=telegram_session

# Database connection - do NOT fill in by hand: scripts\setup_database.bat writes them.
DATABASE_URL_BOT=
DATABASE_URL_COLLECTOR=

# Who can use the bot: Telegram username (with or without @) OR numeric ID, mixable and
# comma-separated. Leave empty on first run if you don't know your ID: start the bot, send it
# /start (you'll be rejected, but the bot console prints your tg_user_id), copy it here, restart.
ADMIN_USER_IDS=
